import http from 'k6/http';
import { check, sleep } from 'k6';

export const options = {
  stages: [
    { duration: '10s', target: 10 },
    { duration: '20s', target: 10 },
    { duration: '5s', target: 0 },
  ],
  thresholds: {
    http_req_failed: ['rate<0.01'],
    http_req_duration: ['p(95)<500'],
  },
};

export default function () {
  let res = http.get('http://127.0.0.1:54515/sqt.html');

  check(res, {
    'Status is 200': (r) => r.status === 200,
    'Page contains CineVerse': (r) => r.body.includes('CineVerse'),
    'Login modal exists': (r) => r.body.includes('Sign in to CineVerse'),
    'Anime list exists': (r) => r.body.includes('Featured'),
    'Page load < 500ms': (r) => r.timings.duration < 500,

  });
  console.log(`Page Load (duration): ${res.timings.duration} ms`);


  sleep(1);
}
