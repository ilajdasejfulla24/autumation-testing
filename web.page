      <option value="Action">⚔️ Action</option><option value="Adventure">🗺️ Adventure</option>
      <option value="Fantasy">✨ Fantasy</option><option value="Drama">🎭 Drama</option>
      <option value="Mystery">🔎 Mystery</option><option value="Horror">👻 Horror</option>
      <option value="Sci-Fi">🚀 Sci-Fi</option><option value="Romance">❤️ Romance</option>
      <option value="Comedy">😄 Comedy</option>
