<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}
:root{--bg:#0f0f0f;--card:#032738;--text:#fff;--accent:#09416c}
body.light{--bg:#f5f5f5;--card:#fff;--text:#222}
body{background:var(--bg);color:var(--text);}

nav{display:flex;justify-content:space-between;align-items:center;padding:12px 20px;background:#000;position:sticky;top:0;z-index:100;flex-wrap:wrap;}
nav h1{color:var(--accent);font-size:1.5rem;}
.nav-controls{display:flex;gap:8px;flex-wrap:wrap;}
nav input,nav select{padding:6px 10px;border:none;border-radius:6px;font-size:0.85rem;background:#2a2a2a;color:#fff;}
body.light nav input,body.light nav select{background:#ddd;color:#000;}
nav input{width:160px;}
nav button{padding:6px 12px;border:none;border-radius:6px;background:var(--accent);color:#fff;cursor:pointer;font-size:0.85rem;}

.watch-badge{position:relative;display:inline-block;}
.watch-count{position:absolute;top:-8px;right:-8px;background:red;color:white;border-radius:50%;width:18px;height:18px;font-size:12px;display:flex;align-items:center;justify-content:center;}

/* LOGIN MODAL (beyaz kare) */
.login-modal{
  position:fixed;
  top:0; left:0; width:100%; height:100%;
  background:rgba(0,0,0,0.9);
  display:flex;
  justify-content:center;
  align-items:center;
  z-index:2000;
}
.login-modal.hidden{display:none;}
.login-card{
  background:white;
  padding:30px 25px;
  border-radius:16px;
  width:320px;
  box-shadow:0 20px 40px rgba(0,0,0,0.5);
  text-align:center;
  color:#222;
}
.login-card h2{
  color:#09416c;
  margin-bottom:20px;
  font-weight:600;
}
.login-card input{
  width:100%;
  padding:12px 15px;
  margin-bottom:15px;
  border:1px solid #ddd;
  border-radius:30px;
  font-size:14px;
  outline:none;
}
.login-card input:focus{border-color:#09416c;}
.login-card button{
  background:#09416c;
  color:white;
  border:none;
  padding:12px 0;
  width:100%;
  border-radius:30px;
  font-weight:600;
  cursor:pointer;
  font-size:16px;
  margin-top:5px;
}
.login-card button:hover{background:#0e5a99;}
.login-small{
  margin-top:15px;
  font-size:13px;
  color:#666;
}

.featured,.section{padding:20px 25px;}
.featured h2,.section h2{margin-bottom:15px;border-left:6px solid var(--accent);padding-left:15px;font-size:1.5rem;}

.slider{display:flex;overflow-x:auto;gap:12px;padding:5px 5px 15px;scrollbar-width:thin;}
.slider-card{min-width:130px;background:var(--card);padding:8px;border-radius:10px;text-align:center;cursor:pointer;position:relative;}
.slider-card:hover{transform:translateY(-5px);box-shadow:0 5px 15px var(--accent);}
.slider-card img{width:100%;height:150px;object-fit:cover;border-radius:8px;}
.slider-card h3{font-size:0.85rem;margin:5px 0;}
.slider-card p{font-size:0.7rem;}
.slider-card .rating{color:gold;background:rgba(0,0,0,0.3);padding:2px 6px;border-radius:12px;font-size:0.7rem;display:inline-block;}

.watch-btn{position:absolute;top:5px;right:5px;background:rgba(0,0,0,0.7);color:#fff;border:none;border-radius:50%;width:30px;height:30px;font-size:18px;cursor:pointer;z-index:10;}
.watch-btn.added{background:gold;color:black;}

.slider-nav{display:flex;justify-content:flex-end;gap:8px;margin-top:5px;}
.slider-nav button{width:32px;height:32px;border-radius:50%;background:var(--accent);color:#fff;border:none;cursor:pointer;font-size:1rem;}

.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;}
.card{background:var(--card);padding:8px;border-radius:10px;text-align:center;position:relative;}
.card:hover{transform:translateY(-5px);box-shadow:0 5px 15px var(--accent);}
.card img{width:100%;height:160px;object-fit:cover;border-radius:8px;margin-bottom:8px;}
.card h3{font-size:0.85rem;}
.card p{font-size:0.7rem;}
.card .desc{font-size:0.65rem;opacity:0.9;font-style:italic;}
.card .rating{color:rgb(198,183,14);background:rgba(0,0,0,0.3);padding:3px 6px;border-radius:12px;font-size:0.7rem;display:inline-block;margin-top:5px;}
.modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.8);z-index:1000;}
.modal.show{display:flex;justify-content:center;align-items:center;}
.modal-content{background:var(--card);padding:20px;border-radius:10px;max-width:500px;width:90%;max-height:80vh;overflow-y:auto;}
.modal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:15px;}
.close-btn{background:none;border:none;color:var(--text);font-size:24px;cursor:pointer;}
.watch-item{display:flex;gap:10px;padding:10px;border-bottom:1px solid rgba(255,255,255,0.1);}
.watch-item img{width:50px;height:70px;object-fit:cover;border-radius:5px;}
.watch-item-info{flex:1;}
.remove-btn{background:#f10606;color:white;border:none;padding:5px 10px;border-radius:5px;cursor:pointer;font-size:0.8rem;}

footer{text-align:center;padding:15px;background:#0e0e0f;margin-top:20px;font-size:0.85rem;}
a{color:gold;text-decoration:none;}
</style>
</head>
