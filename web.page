    <button class="watch-badge" onclick="showWatchList()">📋<span class="watch-count" id="watchCount">0</span></button>
    <button onclick="document.body.classList.toggle('light')">🌓</button>
    <button id="logoutBtn" style="display:none; background:crimson;" onclick="logout()">Logout</button>
  </div>
</nav>

<section class="featured">
  <h2>🔥 Featured</h2>
  <div class="slider" id="featuredSlider"></div>
  <div class="slider-nav">
    <button onclick="document.getElementById('featuredSlider').scrollLeft-=250">←</button>
    <button onclick="document.getElementById('featuredSlider').scrollLeft+=250">→</button>
  </div>
</section>

<section class="section">
  <h2>📺 All (<span id="animeCount">69</span>)</h2>
  <div class="grid" id="animeList"></div>
</section>

<div class="modal" id="watchModal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>📋 My List</h3>
      <button class="close-btn" onclick="this.closest('.modal').classList.remove('show')">&times;</button>
    </div>
    <div id="watchList"></div>
    <div id="watchEmpty" style="text-align:center;padding:20px;">No anime saved yet</div>
  </div>
</div>

<footer>© 2026 CineVerse · <a href="#">Contact</a></footer>

