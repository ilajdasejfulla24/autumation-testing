let watchList = JSON.parse(localStorage.getItem('watchList')) || [];
let loggedIn = localStorage.getItem('cineverseLoggedIn') === 'true';

function saveWatch() {
  localStorage.setItem('watchList', JSON.stringify(watchList));
  document.getElementById('watchCount').innerText = watchList.length;
}

function toggleWatch(anime, e) {
  e.stopPropagation();
  const idx = watchList.findIndex(a => a.title === anime.title);
  idx === -1 ? watchList.push(anime) : watchList.splice(idx, 1);
  saveWatch();
  renderAll();
}

function removeWatch(title) {
  watchList = watchList.filter(a => a.title !== title);
  saveWatch();
  renderAll();
  showWatchList();
}

function showWatchList() {
  if(!loggedIn) { alert('Please login first'); return; }
  const modal = document.getElementById('watchModal');
  const listDiv = document.getElementById('watchList');
  const emptyDiv = document.getElementById('watchEmpty');
  listDiv.innerHTML = watchList.map(a => 
    `<div class="watch-item">
      <img src="${a.image}" onerror="this.src='https://via.placeholder.com/50x70'">
      <div><h4>${a.title}</h4><p>${a.year} | ⭐${a.rating}</p></div>
      <button class="remove-btn" onclick="removeWatch('${a.title.replace(/'/g, "\\'")}')">✕</button>
    </div>`
  ).join('');
  emptyDiv.style.display = watchList.length ? 'none' : 'block';
  modal.classList.add('show');
}

// LOGIN İŞLEMLERİ
function handleLogin(e) {
  e.preventDefault();

  const username = document.getElementById("loginUsername").value.trim();
  const password = document.getElementById("loginPassword").value.trim();

  // ✅ CHECK VALID USERS
  const user = validUsers.find(
    u => u.username === username && u.password === password
  );

  if (!user) {
    alert("Invalid username or password ❌");
    return;
  }

  loggedIn = true;
  localStorage.setItem('cineverseLoggedIn', 'true');

  document.getElementById('loginModal').classList.add('hidden');
  document.getElementById('logoutBtn').style.display = 'inline-block';
}


function logout() {
  loggedIn = false;
  localStorage.setItem('cineverseLoggedIn', 'false');
  document.getElementById('loginModal').classList.remove('hidden');
  document.getElementById('logoutBtn').style.display = 'none';
  watchList = [];
  saveWatch();
  renderAll();
}

function renderAll() {
  const featured = animes.slice(0,10);
  document.getElementById('featuredSlider').innerHTML = featured.map(a => 
    `<div class="slider-card" onclick="alert('${a.title}\\n⭐${a.rating}\\n${a.desc}')">
      <img src="${a.image}" onerror="this.src='https://via.holder.placeholder/130x150'">
      <button class="watch-btn ${watchList.some(w=>w.title===a.title)?'added':''}" onclick="toggleWatch(${JSON.stringify(a).replace(/"/g,'&quot;')},event)">📋</button>
      <h3>${a.title}</h3><p>${a.year}</p><p class="rating">⭐${a.rating}</p>
    </div>`
  ).join('');

  document.getElementById('animeList').innerHTML = animes.map(a => 
    `<div class="card">
      <img src="${a.image}" onerror="this.src='https://via.placeholder.com/140x160'">
      <button class="watch-btn ${watchList.some(w=>w.title===a.title)?'added':''}" onclick="toggleWatch(${JSON.stringify(a).replace(/"/g,'&quot;')},event)">📋</button>
      <h3>${a.title}</h3><p>${a.year} | ${a.genre}</p>
      <p class="desc">${a.desc}</p><p class="rating">⭐${a.rating}</p>
    </div>`
  ).join('');

  document.getElementById('animeCount').innerText = animes.length;
  document.getElementById('watchCount').innerText = watchList.length;
}

